generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // Your Supabase connection string
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  walletAddress String?  @unique
  profile       Json?    // For custom profile data
  logs          Json[]   // User activity logs
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("users")
}